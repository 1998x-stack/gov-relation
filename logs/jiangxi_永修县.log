#!/usr/bin/env python3
"""
TODO Loop Runner — picks the next unfinished item from data/TODO.json
and prints the info needed for the Sisyphus agent to process it.

Usage:
  python3 run_todo_loop.py [--mark-done TASK_ID]
  python3 run_todo_loop.py [--status]
  python3 run_todo_loop.py              # show next item
"""

import json, sys, os

TODO_PATH = "data/TODO.json"

def load_todo():
    return json.load(open(TODO_PATH, encoding='utf-8'))

def save_todo(todo):
    with open(TODO_PATH, 'w', encoding='utf-8') as f:
        json.dump(todo, f, ensure_ascii=False, indent=2)

def find_next(todo):
    """Find the next unfinished item, scanning provinces in order."""
    for prov in todo['provinces']:
        for task in prov.get('tasks', []):
            # ALWAYS check sub-tasks first, regardless of parent done status
            for sub in task.get('sub_tasks', []):
                if not sub.get('done'):
                    return prov['province'], task, sub
