for member in wx yjh zsl liuwei ll gjz lr wsh yyy; do
    name=""
    case $member in
        wx) name="万祥" ;;
        yjh) name="喻建华" ;;
        zsl) name="赵书楼" ;;
        liuwei) name="刘伟" ;;
        ll) name="余晓芳" ;;
        gjz) name="淦家寨" ;;
        lr) name="李荣" ;;
        wsh) name="万顺华" ;;
        yyy) name="袁扬勇" ;;
    esac
    result=$(curl -sL -A "Mozilla/5.0" --max-time 10 "https://www.yongxiu.gov.cn/zwgkx/01_298277/jggk/ldzc_186182/xwcw_186390/${member}/" 2>/dev/null | python3 -c "
import sys, re
html = sys.stdin.read()
html_clean = re.sub(r'<script[^>]*>.*?</script>', '', html, flags=re.DOTALL)
html_clean = re.sub(r'<style[^>]*>.*?</style>', '', html_clean, flags=re.DOTALL)
html_clean = re.sub(r'<[^>]+>', '\n', html_clean)
html_clean = re.sub(r'\n+', '\n', html_clean)
lines = [l.strip() for l in html_clean.split('\n') if l.strip() and len(l.strip()) > 2]
for l in lines:
    if '我的分工' in l or '我的简历' in l or '常委' in l or '主任' in l or '部长' in l or '书记' in l or '县长' in l or '主席' in l or '政法委' in l or '统战' in l or '宣传' in l or '组织' in l or '197' in l or '196' in l or '198' in l or '大学' in l or '研究生' in l or '学士' in l:
        print(l)
" 2>/dev/null)
    echo "=== ${member} (${name}) ==="
    echo "$result"
done
