Excellent! Now let me get all the other standing committee members' details as well. Let me also search for more about 秦岭's whereabouts.
[0m$ [0m# Get all standing committee members
for member in zsl liuwei ll gjz lr wsh yyy; do
    curl -sL -A "Mozilla/5.0" --max-time 10 "https://www.yongxiu.gov.cn/zwgkx/01_298277/jggk/ldzc_186182/xwld/xwcw_186390/${member}/" 2>/dev/null | python3 -c "
import sys, re
html = sys.stdin.read()
html_clean = re.sub(r'<script[^>]*>.*?</script>', '', html, flags=re.DOTALL)
html_clean = re.sub(r'<style[^>]*>.*?</style>', '', html_clean, flags=re.DOTALL)
html_clean = re.sub(r'<[^>]+>', '\n', html_clean)
html_clean = re.sub(r'\n+', '\n', html_clean)
lines = [l.strip() for l in html_clean.split('\n') if l.strip() and len(l.strip()) > 2]
for l in lines:
    print(l)
" 2>/dev/null
    echo "======"
done
