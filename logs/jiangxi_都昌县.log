import sqlite3
conn = sqlite3.connect('/workspace/data/xieming/other-codes/gov-relation/data/database/duchang_network.db')
cur = conn.cursor()
print('=== PERSONS ===')
for row in cur.execute('SELECT id, name, birth, birthplace, education, current_post FROM persons ORDER BY id'):
    print(f'  {row[0]:3d} | {row[1]:8s} | {row[2]:10s} | {row[3]:12s} | {row[4]:20s} | {row[5]}')
print()
print('=== ORGS ===')
for row in cur.execute('SELECT id, name, type, level FROM organizations'):
    print(f'  {row[0]:3d} | {row[1]:30s} | {row[2]:6s} | {row[3]}')
print()
