import sqlite3
conn = sqlite3.connect('data/database/wuning_network.db')
cur = conn.cursor()

print('=== PERSONS ===')
for row in cur.execute('SELECT id, name, current_post, birth, birthplace FROM persons ORDER BY id'):
    print(f'  {row[0]:3d} {row[1]:10s} {row[2][:40]:40s} {row[3] or \"?\":12s} {row[4] or \"?\":10s}')

print()
print('=== ORGANIZATIONS ===')
for row in cur.execute('SELECT id, name, type, level FROM organizations'):
    print(f'  {row[0]:3d} {row[1][:30]:30s} {row[2]:6s} {row[3]}')

print()
print('=== RELATIONSHIPS ===')
for row in cur.execute('SELECT id, person_a_id, person_b_id, type, context FROM relationships ORDER BY id'):
    print(f'  {row[0]:3d} p{row[1]}↔p{row[2]:3d} {row[3]:12s} {row[4][:60]}')
conn.close()
