timestamp=2026-07-14T15:25:37.644Z level=INFO run=bb83b692 message=evaluated permission=bash pattern="python3 -c \"\nimport sys, re, html\ncontent = sys.stdin.read()\n# Extract result links and text\nresults = re.findall(r'<a rel=\\\"nofollow\\\" class=\\\"result__a\\\" href=\\\"(.*?)\\\".*?>(.*?)</a>', content, re.DOTALL)\nsnippets = re.findall(r'class=\\\"result__snippet\\\">(.*?)</a>', content, re.DOTALL)\nprint(f'Found {len(results)} results')\nfor i, (url, title) in enumerate(results[:15]):\n    clean_title = re.sub(r'<.*?>', '', title)\n    clean_title = html.unescape(clean_title)\n    clean_url = html.unescape(url)\n    snippet = html.unescape(re.sub(r'<.*?>', '', snippets[i])) if i < len(snippets) else ''\n    print(f'\\n--- Result {i+1} ---')\n    print(f'Title: {clean_title}')\n    print(f'URL: {clean_url}')\n    print(f'Snippet: {snippet}')\n\"" action.permission=* action.action=allow action.pattern=*
