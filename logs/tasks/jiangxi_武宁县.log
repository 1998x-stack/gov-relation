import sys, re
html = sys.stdin.read()
# Extract title
m = re.search(r'<title>(.*?)</title>', html)
if m: print('Title:', m.group(1))
# Extract leadership info
for p in ['县委书记', '县长', '副书记', '常委']:
    # Try to find nearby text
    idx = html.find(p)
    if idx >= 0:
        print(f'\n--- Found \"{p}\" at position {idx} ---')
        print(html[max(0,idx-200):idx+300])
" 2>/dev/null
