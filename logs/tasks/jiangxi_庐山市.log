import sqlite3
conn = sqlite3.connect('/workspace/data/xieming/other-codes/gov-relation/data/database/lushan_network.db')
cur = conn.cursor()
print('=== PERSONS ===')
cur.execute('SELECT id, name, current_post FROM persons')
for r in cur.fetchall():
    print(f'  {r[0]}: {r[1]} - {r[2]}')
print()

print('=== ORGANIZATIONS ===')
cur.execute('SELECT id, name, type, level FROM organizations')
for r in cur.fetchall():
    print(f'  {r[0]}: {r[1]} ({r[2]}, {r[3]})')
print()

print('=== POSITIONS ===')
cur.execute('SELECT id, person_id, title, start, end, rank FROM positions')
for r in cur.fetchall():
    print(f'  {r[0]}: p{r[1]} - {r[2]} ({r[3]}→{r[4]}) [{r[5]}]')
print()

print('=== RELATIONSHIPS ===')
cur.execute('SELECT id, person_a_id, person_b_id, type, context FROM relationships')
for r in cur.fetchall():
    print(f'  {r[0]}: p{r[1]} ↔ p{r[2]} [{r[3]}] {r[4][:50]}')
print()

cur.execute('SELECT COUNT(*) FROM persons')
print(f'Total persons: {cur.fetchone()[0]}')
cur.execute('SELECT COUNT(*) FROM organizations')
print(f'Total orgs: {cur.fetchone()[0]}')
cur.execute('SELECT COUNT(*) FROM positions')
print(f'Total positions: {cur.fetchone()[0]}')
cur.execute('SELECT COUNT(*) FROM relationships')
print(f'Total relationships: {cur.fetchone()[0]}')
conn.close()
"
