import sqlite3
conn = sqlite3.connect('data/database/上栗县_network.db')
c = conn.cursor()
print('=== PERSONS ===')
for row in c.execute('SELECT id, name, current_post FROM persons ORDER BY id'):
    print(f'  {row[0]:25s} | {row[1]:8s} | {row[2]}')
print()
print('=== ORGANIZATIONS ===')
for row in c.execute('SELECT id, name FROM organizations ORDER BY id'):
    print(f'  {row[0]:30s} | {row[1]}')
print()
print('=== RELATIONSHIPS ===')
for row in c.execute('SELECT person_a, person_b, type, context FROM relationships'):
    print(f'  {row[0]:20s} <-> {row[1]:20s} [{row[2]:6s}] {row[3]}')
conn.close()
