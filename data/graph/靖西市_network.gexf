lue for="9" value="百色市靖西市" /></attvalues></node><node id="100022" label="中共钦州市委员会"><viz:size value="15.0" /><viz:shape value="hexagon" /><viz:color r="220" g="220" b="220" a="0.8" /><attvalues><attvalue for="0" value="organization" /><attvalue for="7" value="党委" /><attvalue for="8" value="地级市" /><attvalue for="9" value="钦州市" /></attvalues></node><node id="100023" label="钦州市人民政府"><viz:size value="15.0" /><viz:shape value="hexagon" /><viz:color r="220" g="220" b="220" a="0.8" /><attvalues><attvalue for="0" value="organization" /><attvalue for="7" value="政府" /><attvalue for="8" value="地级市" /><attvalue for="9" value="钦州市" /></attvalues></node><node id="100024" label="河池市人民政府"><viz:size value="15.0" /><viz:shape value="hexagon" /><viz:color r="220" g="220" b="220" a="0.8" /><attvalues><attvalue for="0" value="organization" /><attvalue for="7" value="政府" /><attvalue for="8" value="地级市" /><attvalue for="9" value="河池市" /></attvalues></node><node id="100025" label="清华大学"><viz:size value="15.0" /><viz:shape value="hexagon" /><viz:color r="220" g="220" b="220" a="0.8" /><attvalues><attvalue for="0" value="organization" /><attvalue for="7" value="事业单位" /><attvalue for="9" value="北京市" /></attvalues></node><node id="100026" label="中国科学技术大学"><viz:size value="15.0" /><viz:shape value="hexagon" /><viz:color r="220" g="220" b="220" a="0.8" /><attvalues><attvalue for="0" value="organization" /><attvalue for="7" value="事业单位" /><attvalue for="9" value="安徽省合肥市" /></attvalues></node></nodes><edges><edge id="1" source="1" target="2"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="郝玉松（市委书记）与刘永雄（市长）为靖西市党政主要领导搭档，自2023年10月起共事。两人在靖西市委工作务虚会、烟叶产业工作部署会、人大会议等多种场合共同出席。" /><attvalue for="2" value="中共靖西市委员会/靖西市人民政府" /><attvalue for="3" value="2023年10月至今" /></attvalues></edge><edge id="2" source="3" target="1"><attvalues><attvalue for="0" value="predecessor_successor" /><attvalue for="1" value="钟恒钦于2016-2021年任靖西市委书记（百色市委常委兼任），郝玉松于2021年7月接任靖西市委书记。两人曾于2020年共同出席靖西版雷神山医院建设活动（钟任市委书记、郝任市长）。" /><attvalue for="2" value="中共靖西市委员会" /><attvalue for="3" value="2016-2021年（钟任书记），2021年至今（郝任书记）" /></attvalues></edge><edge id="3" source="3" target="1"><attvalues><attvalue for="0" value="superior_subordinate" /><attvalue for="1" value="2016-2021年期间，钟恒钦以百色市委常委身份兼任靖西市委书记，郝玉松任靖西市市长，两人曾为靖西市党政正职搭档。" /><attvalue for="2" value="中共靖西市委员会/靖西市人民政府" /><attvalue for="3" value="2016-2021年" /></attvalues></edge><edge id="4" source="1" target="4"><attvalues><attvalue for="0" value="superior_subordinate" /><attvalue for="1" value="郝玉松（市委书记）与黄兰爱（市委副书记，2022.11-2024.06）在靖西市委常委会共事。黄兰爱协助郝玉松处理市委日常工作，分管宣传、乡村振兴等工作。" /><attvalue for="2" value="中共靖西市委员会" /><attvalue for="3" value="2022年11月至2024年6月" /></attvalues></edge><edge id="5" source="2" target="4"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="刘永雄（市长）与黄兰爱（市委副书记）在靖西市党政班子共事约8个月（2023年10月至2024年6月）。" /><attvalue for="2" value="靖西市党政班子" /><attvalue for="3" value="2023年10月至2024年6月" /></attvalues></edge><edge id="6" source="1" target="5"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="郝玉松（市委书记）与闭鸿飞（市委常委、统战部长）在靖西市委常委会共事。闭鸿飞为靖西本地成长干部，长期在靖西任职。" /><attvalue for="2" value="中共靖西市委员会" /><attvalue for="3" value="2021年7月至2025年1月" /></attvalues></edge><edge id="7" source="2" target="5"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="刘永雄（市长）与闭鸿飞（市委常委、统战部长）在靖西市共事。" /><attvalue for="2" value="靖西市" /><attvalue for="3" value="2023年10月至2025年1月" /></attvalues></edge><edge id="8" source="1" target="6"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="郝玉松（市委书记）与何婷婷（市委常委、副市长）在市委常委会和市政府班子共事。" /><attvalue for="2" value="中共靖西市委员会/靖西市人民政府" /><attvalue for="3" value="2024年前至今" /></attvalues></edge><edge id="9" source="2" target="6"><attvalues><attvalue for="0" value="superior_subordinate" /><attvalue for="1" value="刘永雄（市长）与何婷婷（市委常委、副市长）在靖西市政府班子共事，何婷婷为刘永雄的副手。" /><attvalue for="2" value="靖西市人民政府" /><attvalue for="3" value="2023年10月至今" /></attvalues></edge><edge id="10" source="2" target="13"><attvalues><attvalue for="0" value="superior_subordinate" /><attvalue for="1" value="刘永雄（市长）与玉文波（副市长、公安局局长）在靖西市政府班子共事。" /><attvalue for="2" value="靖西市人民政府" /><attvalue for="3" value="2023年10月至今" /></attvalues></edge><edge id="11" source="2" target="14"><attvalues><attvalue for="0" value="superior_subordinate" /><attvalue for="1" value="刘永雄（市长）与吴英杰（副市长）在靖西市政府班子共事。" /><attvalue for="2" value="靖西市人民政府" /><attvalue for="3" value="2023年10月至今" /></attvalues></edge><edge id="12" source="2" target="11"><attvalues><attvalue for="0" value="superior_subordinate" /><attvalue for="1" value="刘永雄（市长）与汪保华（副市长、驻村工作队队长）在靖西市政府班子共事。" /><attvalue for="2" value="靖西市人民政府" /><attvalue for="3" value="2023年10月至今" /></attvalues></edge><edge id="13" source="2" target="12"><attvalues><attvalue for="0" value="superior_subordinate" /><attvalue for="1" value="刘永雄（市长）与冯志刚（副市长、粤桂协作）在靖西市政府班子共事。" /><attvalue for="2" value="靖西市人民政府" /><attvalue for="3" value="2023年10月至今" /></attvalues></edge><edge id="14" source="4" target="5"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="黄兰爱（市委副书记）与闭鸿飞（市委常委、统战部长）在靖西市委常委会共事。" /><attvalue for="2" value="中共靖西市委员会" /><attvalue for="3" value="2022年11月至2024年6月" /></attvalues></edge><edge id="15" source="1" target="18"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="郝玉松（市委书记）与陈飞龙（市人大常委会主任）在靖西市四家班子中共同工作。" /><attvalue for="2" value="靖西市四家班子" /><attvalue for="3" value="2021年至今" /></attvalues></edge><edge id="16" source="2" target="18"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="刘永雄（市长）与陈飞龙（市人大常委会主任）在靖西市四家班子中共同工作。" /><attvalue for="2" value="靖西市四家班子" /><attvalue for="3" value="2023年10月至今" /></attvalues></edge><edge id="17" source="1" target="19"><attvalues><attvalue for="0" value="overlap" /><attvalue for="1" value="郝玉松（市委书记）与陆海（市政协主席）在靖西市四家班子中共同工作。" /><attvalue for="2" value="靖西市四家班子" /><attvalue for="3" value="2021年至今" /></attvalues></edge></edges></graph><meta><title>靖西市</ti