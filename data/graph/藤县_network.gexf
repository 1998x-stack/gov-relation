<gexf xmlns="http://www.gexf.net/1.3" xmlns:viz="http://www.gexf.net/1.3/viz" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.gexf.net/1.3 http://www.gexf.net/1.3/gexf.xsd" version="1.3"><graph mode="static" defaultedgetype="directed"><attributes class="node"><attribute id="0" title="type" type="string" /><attribute id="1" title="current_post" type="string" /><attribute id="2" title="current_org" type="string" /><attribute id="3" title="gender" type="string" /><attribute id="4" title="ethnicity" type="string" /><attribute id="5" title="birth" type="string" /><attribute id="6" title="source" type="string" /><attribute id="7" title="org_type" type="string" /><attribute id="8" title="level" type="string" /><attribute id="9" title="location" type="string" /></attributes><attributes class="edge"><attribute id="0" title="type" type="string" /><attribute id="1" title="context" type="string" /><attribute id="2" title="overlap_org" type="string" /><attribute id="3" title="overlap_period" type="string" /></attributes><nodes><node id="1" label="杨正沛"><viz:size value="60.0" /><viz:shape value="square" /><viz:color r="200" g="30" b="30" a="1.0" /><attvalues><attvalue for="0" value="person" /><attvalue for="1" value="藤县县委书记" /><attvalue for="2" value="中共藤县委员会" /><attvalue for="3" value="待查" /><attvalue for="4" value="待查" /><attvalue for="5" value="待查" /><attvalue for="6" value="confirmed — 藤县政府门户网站「县委常委会召开会议 杨正沛主持」(2026-07-13)、「杨正沛等县四家班子领导参加投票选举人大代表」(2026-07-22)、「杨正沛督导检查登革热防控及爱国卫生运动工作」(2026-07-20)、「杨正沛在藤县'两优一先'表彰大会上强调…」(2026-07-14)。来源: http://www.tengxian.gov.cn/" /></attvalues></node><node id="2" label="余强"><viz:size value="45.0" /><viz:shape value="square" /><viz:color r="220" g="80" b="80" a="0.9" /><attvalues><attvalue for="0" value="person" /><attvalue for="1" value="藤县县委副书记、县长（推测）" /><attvalue for="2" value="藤县人民政府" /><attvalue for="3" value="待查" /><attvalue for="4" value="待查" /><attvalue for="5" value="待查" /><attvalue for="6" value="plausible — 藤县政府门户网站「余强调研登革热防控及爱国卫生运动工作」(2026-07-21)。余强以独立调研身份出现，与杨正沛的督导检查形成书记/县长分工模式，推测余强为县长。需进一步确认来源: http://www.tengxian.gov.cn/" /></attvalues></node><node id="3" label="待查（人大主任）"><viz:size value="30.0" /><viz:shape value="diamond" /><viz:color r="60" g="180" b="60" a="0.85" /><attvalues><attvalue for="0" value="person" /><attvalue for="1" value="藤县人大常委会主任" /><attvalue for="2" value="藤县人民代表大会常务委员会" /><attvalue for="3" value="待查" /><attvalue for="4" value="待查" /><attvalue for="5" value="待查" /><attvalue for="6" value="unverified — 网站提及「县四家班子领导」，人大主任属四家班子之一，但姓名未在首页文章中出现。" /></attvalues></node><node id="4" label="待查（政协主席）"><viz:size value="30.0" /><viz:shape value="diamond" /><viz:color r="60" g="180" b="60" a="0.85" /><attvalues><attvalue for="0" value="person" /><attvalue for="1" value="藤县政协主席" /><attvalue for="2" value="中国人民政治协商会议藤县委员会" /><attvalue for="3" value="待查" /><attvalue for="4" value="待查" /><attvalue for="5" value="待查" /><attvalue for="6" value="unverified — 网站提及「县四家班子领导」，政协主席属四家班子之一，但姓名未在首页文章中出现。" /></attvalues></node><node id="100001" label="中共藤县委员会"><viz:size value="15.0" /><viz:shape value="hexagon" /><viz:color r="220" g="220" b="220" a="0.8" /><attvalues><attvalue for="0" value="organization" /><attvalue for="7" value="党委" /><attvalue for="8" value="县" /><attvalue for="9" value="梧州市藤县" /></attvalues></node><node id="100002" label="藤县人民政府"><viz:size value="15.0" /><viz:shape value="hexagon" /><viz:color r="220" g="220" b="220" a="0.8" /><attvalues><attvalue for="0" value="organization" /><attvalue for="7" value="政府" /><attvalue for="8" value="县" /><attvalue for="9" value="梧州市藤县" /></attvalues></node><node id="100003" label="藤县人民代表大会常务委员会"><viz:size value="15.0" /><viz:shape value="hexagon" /><viz:color r="220" g="220" b="220" a="0.8" /><attvalues><attvalue for="0" value="organization" /><attvalue for="7" value="人大" /><attvalue for="8" value="县" /><attvalue for="9" value="梧州市藤县" /></attvalues></node><node id="100004" label="中国人民政治协商会议藤县委员会"><viz:size val