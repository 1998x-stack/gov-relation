    <edges>
      <edge id="1" source="p1" target="o1" label="郁南县委书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="现任。主持县委全面工作。1974年3月生，广东开平人，大学学历，1995年5月入党，1996年7月参加工作。此前曾任郁南县委副书记、县长。"/>
        </attvalues>
      </edge>
      <edge id="2" source="p2" target="o2" label="郁南县委常委、副县长（常务）" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="现任。协助县长处理县政府日常工作。1974年6月生，广东罗定人，大学学历，1996年7月入党，1995年8月参加工作。县长空缺期间主持县政府日常工作。"/>
        </attvalues>
      </edge>
      <edge id="3" source="p2" target="o1" label="郁南县委常委" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="现任县委常委，兼任县政府党组副书记、副县长。"/>
        </attvalues>
      </edge>
      <edge id="4" source="p3" target="o1" label="郁南县委副书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="现任。协助县委书记抓党的建设工作，处理县委日常事务。兼任县委政法委书记。1981年2月生，广东电白人。"/>
        </attvalues>
      </edge>
      <edge id="5" source="p3" target="o7" label="郁南县委政法委书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="兼任。负责政法、维护社会稳定工作。"/>
        </attvalues>
      </edge>
      <edge id="6" source="p4" target="o1" label="挂任郁南县委副书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="挂任。广东省文化和旅游发展与保障中心副主任下派。1978年4月生，广东兴宁人，研究生学历。"/>
        </attvalues>
      </edge>
      <edge id="7" source="p5" target="o1" label="郁南县委常委" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="现任。兼任县委办公室主任、宣传部部长。1976年6月生，广东信宜人。"/>
        </attvalues>
      </edge>
      <edge id="8" source="p5" target="o9" label="郁南县委宣传部部长" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="兼任。负责宣传思想、文化、意识形态工作。"/>
        </attvalues>
      </edge>
      <edge id="9" source="p6" target="o1" label="郁南县委常委" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="现任。负责科技、工信、商务、市监、林业等工作。1982年5月生，广东云安人，研究生学历。"/>
        </attvalues>
      </edge>
      <edge id="10" source="p7" target="o5" label="郁南县委常委、纪委书记、监委主任" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="现任。负责纪检监察、党风廉政建设工作。1978年8月生，广东云安人。2013年8月入党，2001年10月参加工作。"/>
        </attvalues>
