          <attvalue for="1" value="前任区委书记，2021年9月调任沙坪坝区委书记"/>
        </attvalues>
      </edge>
      <edge id="e16" source="tongliang_chen_yong" target="org_tongliang_party" label="铜梁区委书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="首任铜梁区委书记（撤县设区后）"/>
        </attvalues>
      </edge>
      <edge id="e17" source="tongliang_tan_qing" target="tongliang_wan_long" label="党政一把手" weight="2.0">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="谭庆（区委书记）与万隆（区委副书记、区长）为铜梁区党政一把手搭档关系。谭庆曾任区长时，万隆为其常务副区长，后万隆接任区长，形成书记一区长的传帮带关系。"/>
          <attvalue for="2" value="strong"/>
        </attvalues>
      </edge>
      <edge id="e18" source="tongliang_tan_qing" target="tongliang_zhou_yonggang" label="区委正副书记" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="谭庆（区委书记）与周永刚（区委专职副书记）为区委班子正副书记关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e19" source="tongliang_tan_qing" target="tongliang_wang_qiaosheng" label="区委—纪委" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="谭庆（区委书记）与汪桥生（区纪委书记）为党风廉政建设的领导与被领导关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e20" source="tongliang_wan_long" target="tongliang_long_qi" label="区长—常务副区长" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="龙骑作为常务副区长，协助万隆区长处理区政府日常工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e21" source="tongliang_tan_qing" target="tongliang_li_zhaolong" label="区委—组织部" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="李兆龙（组织部部长）在区委书记谭庆领导下管理干部选拔任用工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e22" source="tongliang_tan_qing" target="tongliang_yang_guozhong" label="区委—政法委" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="杨国忠（政法委书记）在区委领导下负责铜梁区政法工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e23" source="tongliang_tan_qing" target="tongliang_wang_xiaobo" label="区委—宣传部" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="王小波（宣传部部长）在区委书记领导下负责全区宣传思想工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e24" source="tongliang_tan_qing" target="tongliang_liao_yun" label="区委—统战部" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="廖云（统战部部长）在区委书记领导下负责全区统一战线工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e25" source="tongliang_tan_qing" target="tongliang_zhu_hualun" label="区委—区人大" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="谭庆（区委书记）与朱华伦（区人大常委会主任）为党政主要领导与人大领导的关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e26" source="tongliang_tan_qing" target="tongliang_he_jianwei" label="区委—区政协" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="谭庆（区委书记）与何建伟（区政协主席）为党政主要领导与政协领导的关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e27" source="tongliang_tan_qing" target="tongliang_wan_long" label="前任继任/传帮带" weight="2.0">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="谭庆在担任铜梁区长时，万隆时任常务副区长。谭庆晋升区委书记后，万隆接任区长。二人是典型的区长-常务副区长然后书记-区长关系。"/>
          <attvalue for="2" value="strong"/>
        </attvalues>
      </edge>
      <edge id="e28" source="tongliang_tang_xiaoping" target="tongliang_tan_qing" label="前任继任" weight="2.0">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="唐小平（2018-2021年任铜梁区委书记）后调任沙坪坝区委书记，由谭庆接任铜梁区委书记。"/>
          <attvalue for="2" value="strong"/>
        </attvalues>
      </edge>
      <edge id="e29" source="tongliang_chen_yong" target="tongliang_tang_xiaoping" label="前任继任" weight="2.0">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="陈勇为铜梁撤县设区后首任区委书记（2014-2018），后由唐小平接任。"/>
          <attvalue for="2" value="strong"/>
        </attvalues>
      </edge>
      <edge id="e30" source="tongliang_tang_xiaoping" target="tongliang_tan_qing" label="跨区交接" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="唐小平调任沙坪坝区委书记后，谭庆接任铜梁区委书记。铜梁与沙坪坝之间存在领导干部交流关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
    </edges>
