          <attvalue for="1" value="2006-2026"/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="袁一旦从安义副县长起步，经进贤、西湖区、市交通局，至青山湖区委书记。熊振强从安义县委常委起步，经西湖区、市公路中心、市交通局，至进贤县委书记。二人路径高度相似"/>
        </attvalues>
      </edge>
