        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2021"/>
          <attvalue for="2" value="2025"/>
          <attvalue for="3" value="2021年任全南县长。2023-2025年连续以县长身份作政府工作报告。"/>
        </attvalues>
      </edge>
      <edge id="5" source="p2" target="o2" label="龙南市委副书记、市长候选人" weight="1.0">
