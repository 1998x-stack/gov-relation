          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2026-07"/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="2026年7月3日以市委副书记、市长候选人，经开区党工委副书记、管委会主任提名人选身份走访重点企业。7月3日与边建忠一同调研。"/>
        </attvalues>
      </edge>
