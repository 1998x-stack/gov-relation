    <edges>
      <edge id="1" source="p1" target="o1" label="龙南市委书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2026-07"/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="2026年7月初由全南县委书记调任龙南市委书记。7月7日任龙南市人武部党委第一书记。7月3日走访重点企业，7月4日四不两直督导乡镇，7月9日讲授专题党课。"/>
        </attvalues>
      </edge>
      <edge id="2" source="p1" target="o3" label="龙南经开区党工委书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2026-07"/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="兼任龙南经开区党工委书记。"/>
        </attvalues>
      </edge>
      <edge id="3" source="p1" target="o4" label="全南县委书记（前任）" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2025"/>
          <attvalue for="2" value="2026-07"/>
          <attvalue for="3" value="由县长升任县委书记。2026年6月9日主持政绩观学习教育整改整治推进会。6月29日主持庆祝建党105周年大会。2026年7月初调离。"/>
        </attvalues>
      </edge>
