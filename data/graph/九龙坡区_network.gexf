      <edge id="e15" source="jiulongpo_li_chunkui" target="jiulongpo_li_shun" label="党政一把手" weight="2.0">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="李春奎（区委书记）与李顺（区委副书记、区长）为九龙坡区党政一把手搭档关系。二人共同主持区委常委会和全区重要工作。"/>
          <attvalue for="2" value="strong"/>
        </attvalues>
      </edge>
      <edge id="e16" source="jiulongpo_li_chunkui" target="jiulongpo_luo_linquan" label="区委正副书记" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="李春奎（区委书记）与罗林泉（区委专职副书记）为区委班子正副书记关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e17" source="jiulongpo_li_chunkui" target="jiulongpo_liu_wenming" label="区委—纪委" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="李春奎（区委书记）与刘文明（区纪委书记）为党风廉政建设的领导与被领导关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e18" source="jiulongpo_li_shun" target="jiulongpo_chen_guanhong" label="区长—常务副区长" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="陈关洪作为常务副区长，协助李顺区长处理区政府日常工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e19" source="jiulongpo_li_shun" target="jiulongpo_he_jia" label="区长—副区长" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="何嘉作为副区长，在李顺区长领导下分管相关工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e20" source="jiulongpo_li_chunkui" target="jiulongpo_tu_kaixiang" label="区委—组织部" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="涂开祥（组织部部长）在区委书记李春奎领导下管理干部选拔任用工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e21" source="jiulongpo_li_chunkui" target="jiulongpo_zhao_yong" label="区委—政法委" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="赵勇（政法委书记）在区委领导下负责九龙坡区政法工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e22" source="jiulongpo_li_chunkui" target="jiulongpo_cheng_biao" label="区委—宣传部" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="程彪（宣传部部长）在区委书记领导下负责全区宣传思想工作。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e23" source="jiulongpo_li_chunkui" target="jiulongpo_zheng_heping" label="区委—区人大" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="李春奎（区委书记）与郑和平（区人大常委会主任）为党政主要领导与人大领导的关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e24" source="jiulongpo_li_chunkui" target="jiulongpo_song_hong" label="区委—区政协" weight="1.5">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="李春奎（区委书记）与宋泓（区政协主席）为党政主要领导与政协领导的关系。"/>
          <attvalue for="2" value="medium"/>
        </attvalues>
      </edge>
      <edge id="e25" source="jiulongpo_liu_xiaoqiang" target="jiulongpo_li_chunkui" label="前任继任" weight="2.0">
        <attvalues>
          <attvalue for="0" value="relationship"/>
          <attvalue for="1" value="刘小强（2015-2021年任区委书记）后由李春奎接任九龙坡区委书记职务。"/>
          <attvalue for="2" value="strong"/>
        </attvalues>
