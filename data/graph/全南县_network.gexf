    <edges>
      <edge id="1" source="p1" target="o1" label="全南县委书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2026-07"/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="2026年7月3日首次以县委书记身份主持县委常委会第111次(扩大)会议。7月8日讲授树立和践行正确政绩观学习教育专题党课。1977-11生，江西会昌人，中央党校大学。1997.08参加工作。此前为全南县委副书记、县长。"/>
        </attvalues>
      </edge>
      <edge id="2" source="p1" target="o2" label="全南县委副书记、县长（前任）" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value="2026-07"/>
          <attvalue for="3" value="2026年6月29日庆祝建党105周年大会时仍以县长身份主持。2026年2月28日在县十九届人大六次会议上作政府工作报告。约2026年7月初升任县委书记。1997-08参加工作，此前曾任宁都县委常委、兴国县委副书记、赣州市城管局党组书记等职。"/>
        </attvalues>
      </edge>
      <edge id="3" source="p2" target="o1" label="全南县委副书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2026-07"/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="2026年7月3日县委常委会第111次会议首次以县委副书记身份出席。"/>
        </attvalues>
      </edge>
      <edge id="4" source="p2" target="o2" label="全南县长候选人" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2026-07"/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="2026年7月3日以县委副书记、县长候选人身份出席县委常委会。7月8日主持县政府政绩观学习教育整改整治工作推进会。此前为全南县委常委、副县长。"/>
        </attvalues>
      </edge>
      <edge id="5" source="p2" target="o2" label="全南县委常委、副县长（前任）" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value="2026-07"/>
          <attvalue for="3" value="此前为全南县委常委、县政府副县长。2026年7月上旬调研重点企业和防汛减灾工作（此时已为县长候选人）。"/>
        </attvalues>
      </edge>
      <edge id="6" source="p3" target="o1" label="全南县委书记（前任）" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2025"/>
          <attvalue for="2" value="2026-07"/>
          <attvalue for="3" value="约2025年由县长升任县委书记。2026年6月9日主持政绩观学习教育整改整治推进会。6月29日主持庆祝建党105周年大会。2026年7月初调任龙南市委书记、龙南经开区党工委书记。1978-07生，江西峡江人，华东政法大学。1997-08工作，2001-04入党。曾任省委统战部干部、瑞金市副市长、全南组织部长、崇义常务副县长/副书记、全南县长/书记。"/>
        </attvalues>
      </edge>
      <edge id="7" source="p3" target="o2" label="全南县长（前任）" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value="2021"/>
          <attvalue for="2" value="2025"/>
          <attvalue for="3" value="2021年任全南县长。2023-2025年连续以县长身份在县人代会上作政府工作报告。约2025年升任县委书记。此前曾任崇义县委副书记、崇义常务副县长、全南组织部长、瑞金副市长等职。"/>
        </attvalues>
      </edge>
      <edge id="8" source="p4" target="o1" label="全南县委副书记" weight="1.0">
        <attvalues>
          <attvalue for="0" value="worked_at"/>
          <attvalue for="1" value=""/>
          <attvalue for="2" value=""/>
          <attvalue for="3" value="现任。2026年6月29日在庆祝建党105周年大会上宣读表彰决定。2026年7月3日在县委常委会第111次会议在座。"/>
        </attvalues>
      </edge>
      <edge id="9" source="p5" target="o1" label="全南县委常委" weight="1.0">
